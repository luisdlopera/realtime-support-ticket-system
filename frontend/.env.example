# ============================================
# Frontend Environment Variables Example
# ============================================

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# WebSocket/Socket.IO URL
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001/realtime

# App Name
NEXT_PUBLIC_APP_NAME="Support Console"

# App Version
NEXT_PUBLIC_APP_VERSION=1.0.0
