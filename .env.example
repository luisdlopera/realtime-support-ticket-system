# ============================================
# WhatsApp Cloud API Configuration (Meta)
# ============================================

# From Meta Developer Dashboard > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# System User Token or Long-lived Token with whatsapp_business_messaging permission
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# App Secret (from App Settings > Basic) - Required for webhook signature verification
WHATSAPP_APP_SECRET=your_app_secret_here

# Your custom verification token for webhook setup (choose any string)
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# ============================================
# Cloudflare R2 Configuration (for media files)
# ============================================

# Cloudflare Account ID
R2_ACCOUNT_ID=your_cloudflare_account_id

# S3 API Access Keys (from R2 API Tokens)
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key

# R2 Bucket name
R2_BUCKET=support-media

# Public URL for media (e.g., https://pub-xxx.r2.dev)
# Note: Must be public for WhatsApp to access media
R2_PUBLIC_BASE_URL=https://your-bucket.r2.dev
