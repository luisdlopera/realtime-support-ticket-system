# ============================================
# REALTIME SUPPORT TICKET SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ============================================

# ============================================
# Environment Mode
# ============================================
# development | production | test
NODE_ENV=production

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/support

# ============================================
# Redis Configuration
# ============================================
# Redis URL for rate limiting and pub/sub
# Required for production (distributed rate limiting)
REDIS_URL=redis://localhost:6379

# ============================================
# JWT Configuration
# ============================================
# Generate with: openssl rand -base64 32
# MUST be at least 32 characters in production
JWT_SECRET=your_super_secure_random_key_min_32_chars

# JWT expiration times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Security Configuration
# ============================================
# Rate limiting settings
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW_MS=900000

# ============================================
# Backend Server Configuration
# ============================================
PORT=3001

# ============================================
# Frontend URL (for CORS and redirects)
# ============================================
FRONTEND_URL=http://localhost:3002

# ============================================
# Email Configuration (for password reset)
# ============================================
# Options: console | sendgrid
EMAIL_SERVICE=console
EMAIL_FROM=noreply@yourdomain.com

# Only required if using SendGrid
# First install: npm install @sendgrid/mail
# SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ============================================
# Demo Users Configuration (Seed)
# ============================================
# Set to "true" ONLY in production if you need demo users
CREATE_DEMO_USERS=false

# Custom password for demo users (if not set, auto-generates secure random password)
# DEMO_PASSWORD=YourDemoPassword123!

# ============================================
# API Version
# ============================================
npm_package_version=1.0.0

# ============================================
# WhatsApp Cloud API Configuration (Meta)
# ============================================
# Get these from: https://developers.facebook.com/apps

# From Meta Developer Dashboard > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# System User Token with whatsapp_business_messaging permission
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# App Secret (from App Settings > Basic) - REQUIRED for webhook verification
WHATSAPP_APP_SECRET=your_app_secret_here

# Your custom verification token for webhook (choose any secure string)
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_123

# WhatsApp Graph API Version (optional, defaults to v21.0)
WHATSAPP_GRAPH_VERSION=v21.0

# ============================================
# Cloudflare R2 Configuration (for media storage)
# ============================================
# Required for WhatsApp media (images, videos, documents)

# Cloudflare Account ID (from R2 dashboard)
R2_ACCOUNT_ID=your_cloudflare_account_id

# R2 S3 API Access Keys (create in R2 API Tokens)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# R2 Bucket name
R2_BUCKET=support-media

# Public URL for accessing media (must be public for WhatsApp)
# Format: https://pub-<hash>.r2.dev or your custom domain
R2_PUBLIC_BASE_URL=https://your-bucket.r2.dev

# Presigned URL expiration time in seconds (default: 3600 = 1 hour)
R2_SIGNED_TTL=3600

# ============================================
# Frontend Public Environment Variables
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001/realtime

# ============================================
# Monitoring & Logging (Optional)
# ============================================
# Log level: debug | info | warn | error
LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# ============================================
# Production Deployment (Optional)
# ============================================
# SSL Certificate paths (if not using reverse proxy)
# SSL_KEY_PATH=/path/to/private.key
# SSL_CERT_PATH=/path/to/certificate.crt
